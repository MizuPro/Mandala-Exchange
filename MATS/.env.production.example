APP_ENV=production
MATS_HTTP_ADDR=127.0.0.1:8083
MATS_DATABASE_URL=postgres://mandala_mats_prod:replace-with-prod-db-password@localhost:5534/mandala_mats_prod?sslmode=disable
MATS_SERVICE_TOKENS=[{"name":"sekuritas","token":"replace-with-prod-sekuritas-to-mats-token-min-32-chars","scopes":["order:write","order:read","market:read"]},{"name":"bei","token":"replace-with-prod-bei-to-mats-token-min-32-chars","scopes":["admin:read","market:read"]},{"name":"admin","token":"replace-with-prod-admin-token-min-32-chars","scopes":["admin:*","sync:write","order:read","market:read"]}]
BEI_BASE_URL=http://localhost:4101/v1
BEI_SERVICE_TOKEN=replace-with-prod-mats-to-bei-token-min-32-chars
SEKURITAS_EVENTS_URL=http://localhost:3003/internal/mats/events
SEKURITAS_SERVICE_TOKEN=replace-with-prod-mats-to-sekuritas-token-min-32-chars
MATS_SESSION_ID=production-session
MATS_SYNC_INTERVAL_SECONDS=60
MATS_DELIVERY_MAX_ATTEMPTS=5
REDIS_URL=redis://localhost:6380
